{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://chapi.cloudhealthtech.com/*" }]
    },
    {
      "identifier": "store:default",
      "allow": [{ "path": "credentials.json" }]
    },
    "shell:default"
  ]
}
